from Crypto.Util.number import long_to_bytes

def ascii_from_string(m):
    length = (m.bit_length() + 7) // 8

    byte_string = m.to_bytes(length, byteorder="big")

    return byte_string.decode("ascii", errors="ignore")

def monoprime():
    n =                                                                   
    e = 65537
    ct =   

    d = pow(e, -1, n-1)
    m = pow(ct, d, n)

    print(ascii_from_string(m))


def manyprime():
    n = 
    e = 65537
    ct = 
    res = [p[0] for p in list(n.factor(algorithm="ecm"))]
    moduli = [p-1 for p in res]
    exps = [pow(e, -1, modulus) for modulus in moduli]
    d = crt(exps, moduli)
    m = pow(ct, d, n)
    print(ascii_from_string(m))
    

